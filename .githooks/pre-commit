#!/usr/bin/env bash
# Heuristic guard for the project's hard rule: never send raw MAC / a
# per-client hash over BLE or to the mobile app - only aggregated counts
# (see docs/DECISIONS.md D3). This catches obvious cases (path + pattern
# match), it is not a proof. False positive? commit with --no-verify
# once you're sure.

set -e

staged=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$staged" ] && exit 0

offenders=""

for f in $staged; do
    case "$f" in
        mobile/*|*ble*|*BLE*|*gatt*|*GATT*)
            if git show ":$f" 2>/dev/null | grep -Ei '"mac"|src_mac|%02x%02x%02x%02x%02x%02x' >/dev/null 2>&1; then
                offenders="$offenders $f"
            fi
            ;;
    esac
done

if [ -n "$offenders" ]; then
    echo "pre-commit: possible raw MAC leak toward BLE/mobile in:$offenders"
    echo "hard rule: never send raw MAC / per-client hash over BLE or to the app - aggregates only (docs/DECISIONS.md D3)."
    echo "false positive? git commit --no-verify"
    exit 1
fi

exit 0
